.gitignore

include_rules

# Generate Tests
: test_cl_chan.sh |> !calls-linter |> test_cl_chan.gen-s {gen-test}
: test_cl_set.sh |> !calls-linter |> test_cl_set.lowerscreen.gen-s test_cl_set.printer.gen-s test_cl_set.upperscreen.gen-s {gen-test}
: test_co_temp_5.sh |> !calls-linter |> test_co_temp_5.flash_bright.gen-s test_co_temp_5.ink_paper.gen-s test_co_temp_5.inverse_over.gen-s {gen-test}
: test_pixel_addr.sh |> !calls-linter |> test_pixel_addr.gen-s {gen-test}
: test_plot_sub_1.sh |> !calls-linter |> test_plot_sub_1.gen-s {gen-test}
: test_po_any.sh |> !calls-linter |> %B.00.gen-s %B.01.gen-s %B.10.gen-s %B.11.gen-s {gen-test}
: test_po_attr.sh |> !calls-linter |> test_po_attr.gen-s {gen-test}
: test_po_mosaic_half.sh |> !calls-linter |> test_po_mosaic_half.gen-s {gen-test}
: test_po_scr.sh |> !calls-linter |> test_po_scr.lowerscreen.gen-s test_po_scr.upperscreen.gen-s {gen-test}
: test_po_t_udg.sh |> !calls-linter |> %B.f000.gen-s %B.f001.gen-s %B.f010.gen-s %B.f011.gen-s %B.f100.gen-s %B.f101.gen-s %B.f110.gen-s %B.f111.gen-s %B.s000.gen-s %B.s001.gen-s %B.s010.gen-s %B.s011.gen-s %B.s100.gen-s %B.s101.gen-s %B.s110.gen-s %B.s111.gen-s {gen-test}
: test_po_table_1.sh |> !calls-linter |> test_po_table_1.gen-s {gen-test}
: test_po_tokens.sh |> !calls-linter |> %B.f0.gen-s %B.f1.gen-s %B.s0.gen-s %B.s1.gen-s {gen-test}

# Generate Test Runners
: foreach test_*.s test_*.gen-s | ../../../utils/linter/linter |> ^o^ ./tests.sh %f > %o |> %B.suite
: foreach *.suite | ../../../utils/linter/linter |> ^o^ ./suites.sh %f > %o |> %B.runner <runners>
: *.suite | ../../../utils/linter/linter |> ^o^ ./suites.sh %f > %o |> all_suites.runner

# Check sources are formatted
: foreach * ^.gitignore |> !lint |>
