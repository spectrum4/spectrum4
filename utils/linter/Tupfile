.gitignore
# List source files explicitly so that test file changes don't rebuild the
# linter binary (which would retrigger all lint checks across the repo).
: |> ^o^ go build -trimpath -buildvcs=false -ldflags="-buildid=" -mod=readonly -o %o main.go filetype.go gofmt.go rules.go shfmt.go |> linter
: linter |> go test *.go >/dev/null |>
# Cannot !lint own source files — circular dependency (linter binary depends on them).
# Go formatting is enforced by gofmt via lint.sh.
